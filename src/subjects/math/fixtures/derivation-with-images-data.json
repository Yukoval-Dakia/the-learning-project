      "rubric_json": {
        "criteria": [{ "name": "method", "weight": 1, "descriptor": "等腰三角形性质 + 内角和" }],
        "reference_solution": {
          "expected_signals": [
            "识别等腰三角形 AB=AC",
            "对应角相等 ∠C=70°",
            "内角和 180° 推得 ∠A=40°"
          ],
          "final_answer": "40°",
          "answer_equivalents": ["40 度", "∠A = 40°", "= 40°"]
        }
      },
      "difficulty": 2,
      "knowledge_hint": "等腰三角形 / 三角形内角和",
      "image_refs": ["placeholder-isoceles-triangle"]
