{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/codex-session-start.mjs\"",
            "statusMessage": "Recording dirty-file baseline"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/codex-bash-workflow-guard.mjs\"",
            "statusMessage": "Checking workflow friction"
          },
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.claude/hooks/git-guard.mjs\"",
            "statusMessage": "Checking git command"
          },
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.claude/hooks/linear-guard.mjs\"",
            "statusMessage": "Checking Linear YUK-NN on commit"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/post-fetch-divergence.sh\"",
            "statusMessage": "Checking upstream divergence"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/codex-stop-edit-check.mjs\"",
            "statusMessage": "Checking dirty JSON files"
          }
        ]
      }
    ]
  }
}
