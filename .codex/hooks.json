{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/codex-session-start.mjs\"",
            "statusMessage": "Loading repo search guidance"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/codex-apply-patch-json-guard.mjs\"",
            "statusMessage": "Checking JSON patch"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.claude/hooks/git-guard.mjs\"",
            "statusMessage": "Checking git command"
          },
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.claude/hooks/linear-guard.mjs\"",
            "statusMessage": "Checking Linear YUK-NN on commit"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/codex-post-edit-check.mjs\"",
            "statusMessage": "Checking edited files"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/post-fetch-divergence.sh\"",
            "statusMessage": "Checking upstream divergence"
          }
        ]
      }
    ]
  }
}
