{
  "name": "the-learning-project",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "tsx scripts/dev-local.ts",
    "dev:local": "tsx scripts/dev-local.ts",
    "build": "pnpm rw:web:build && pnpm build:server && pnpm build:worker && pnpm build:migrate",
    "build:worker": "esbuild scripts/worker.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/worker.cjs --external:pg-native --external:sharp --external:bufferutil --external:utf-8-validate --define:process.env.NODE_ENV=\\\"production\\\"",
    "build:migrate": "esbuild scripts/migrate.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/migrate.cjs --external:pg-native --external:bufferutil --external:utf-8-validate --define:process.env.NODE_ENV=\\\"production\\\"",
    "start": "node dist/server.cjs",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "pnpm audit:profile && pnpm test:unit && pnpm test:db && pnpm test:migration",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:unit:watch": "vitest --config vitest.unit.config.ts",
    "test:watch": "vitest --config vitest.unit.config.ts",
    "test:db": "vitest run --config vitest.db.config.ts",
    "test:db:watch": "vitest --config vitest.db.config.ts",
    "test:migration": "vitest run --config vitest.migration.config.ts",
    "smoke:local": "tsx scripts/smoke-local.ts",
    "api:smoke": "tsx scripts/api-smoke.ts",
    "gen:postman": "tsx scripts/gen-postman.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:local": "tsx scripts/migrate-local-db.ts",
    "worker:dev": "tsx scripts/worker.ts",
    "seed:synthetic": "tsx scripts/seed-synthetic.ts",
    "audit:schema": "tsx scripts/audit-schema-writes.ts",
    "audit:partition": "tsx scripts/audit-test-partition.ts",
    "audit:profile": "tsx scripts/audit-profile.ts",
    "compile:profile": "tsx scripts/compile-profile.ts",
    "docs:linear-manifest": "tsx scripts/linear-doc-manifest.ts",
    "preflight:vision": "tsx scripts/preflight-vision.ts",
    "preflight:ingestion": "tsx scripts/ingestion-preflight.ts",
    "sanity:vision-rejudge": "tsx scripts/sanity-vision-rejudge.ts",
    "compose:up": "docker compose up -d",
    "compose:down": "docker compose down",
    "compose:build": "docker compose build",
    "db:dump": "docker compose exec postgres pg_dump -U ${POSTGRES_USER:-loom} ${POSTGRES_DB:-loom} > /tmp/loom-$(date +%Y%m%d-%H%M%S).sql",
    "db:restore": "docker compose exec -T postgres psql -U ${POSTGRES_USER:-loom} ${POSTGRES_DB:-loom}",
    "rw:api": "RW_WORKER=1 tsx watch server/index.ts",
    "rw:web": "vite --config web/vite.config.ts",
    "rw:web:build": "vite build --config web/vite.config.ts",
    "build:server": "esbuild server/index.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/server.cjs --external:pg-native --external:sharp --external:bufferutil --external:utf-8-validate --external:@anthropic-ai/claude-agent-sdk --define:process.env.NODE_ENV=\\\"production\\\"",
    "rw:build": "pnpm rw:web:build && pnpm build:server"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@anthropic-ai/claude-agent-sdk": "^0.3.168",
    "@anthropic-ai/sdk": "^0.102.0",
    "@aws-sdk/client-s3": "^3.1063.0",
    "@hono/node-server": "^2.0.4",
    "@hyzyla/pdfium": "^2.1.13",
    "@paralleldrive/cuid2": "^2.2.2",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "@tiptap/core": "^3.26.0",
    "@tiptap/extension-link": "^3.26.0",
    "@tiptap/pm": "^3.26.0",
    "@tiptap/react": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "@tiptap/suggestion": "^3.26.0",
    "ai": "^6.0.197",
    "client-zip": "^2.5.0",
    "cytoscape": "^3.34.0",
    "cytoscape-fcose": "^2.2.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.7.1",
    "fflate": "^0.8.3",
    "hono": "^4.12.25",
    "katex": "^0.17",
    "lucide-react": "^0.468.0",
    "mathjs": "^15.2.0",
    "mem0ai": "3.0.6",
    "pg": "^8.21.0",
    "pg-boss": "^12.18.2",
    "postgres": "^3.4.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^9",
    "rehype-katex": "^7",
    "remark-math": "^6",
    "sharp": "^0.34.5",
    "tencentcloud-sdk-nodejs-ocr": "^4.1.243",
    "ts-fsrs": "^5.4.1",
    "zod": "^3.25.0",
    "zod-to-json-schema": "^3.25.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testcontainers/postgresql": "^10.13.0",
    "@types/katex": "^0.16.8",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "tailwindcss": "^4.0.0",
    "testcontainers": "^10.13.0",
    "tsx": "^4.22.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "overrides": {
      "tmp@<0.2.6": ">=0.2.6",
      "undici@<6.24.0": ">=6.24.0 <7",
      "protobufjs@<=7.5.7": ">=7.5.8 <8",
      "postcss@<8.5.10": ">=8.5.10 <9",
      "uuid@<11.1.1": ">=11.1.1 <12",
      "hono@<4.12.21": ">=4.12.21 <5",
      "esbuild@<0.25.0": ">=0.25.0"
    }
  }
}
