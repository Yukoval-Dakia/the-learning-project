{
  "name": "the-learning-project",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.13.1",
  "scripts": {
    "dev": "tsx scripts/dev-local.ts",
    "dev:local": "tsx scripts/dev-local.ts",
    "build": "pnpm rw:web:build && pnpm build:server && pnpm build:worker && pnpm build:migrate",
    "build:worker": "esbuild scripts/worker.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/worker.cjs --external:pg-native --external:sharp --external:better-sqlite3 --external:bufferutil --external:utf-8-validate --external:@anthropic-ai/claude-agent-sdk --define:process.env.NODE_ENV=\\\"production\\\"",
    "build:migrate": "esbuild scripts/migrate.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/migrate.cjs --external:pg-native --external:bufferutil --external:utf-8-validate --define:process.env.NODE_ENV=\\\"production\\\"",
    "build:native": "cd crates/calibration-native && pnpm --package=@napi-rs/cli@3.7.2 dlx napi build --release",
    "build:native:wasm": "cd crates/calibration-native && pnpm install --ignore-workspace --prefer-offline && pnpm --package=@napi-rs/cli@3.7.2 dlx napi build --release --target wasm32-wasip1-threads --platform && rm -f calibration-native.wasm32-wasi.debug.wasm",
    "start": "node dist/server.cjs",
    "typecheck": "tsc --noEmit",
    "typecheck:legacy": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "pnpm audit:api-contracts && pnpm audit:profile && pnpm audit:learner-copy && pnpm audit:no-learning-styles && pnpm audit:draft-status && pnpm audit:draft-status-reads --strict && pnpm test:unit && pnpm test:db && pnpm test:migration",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:unit:watch": "vitest --config vitest.unit.config.ts",
    "test:watch": "vitest --config vitest.unit.config.ts",
    "test:db": "vitest run --config vitest.db.config.ts",
    "test:db:watch": "vitest --config vitest.db.config.ts",
    "test:migration": "vitest run --config vitest.migration.config.ts",
    "test:usability:static": "pnpm audit:learner-copy && vitest run --config vitest.unit.config.ts web/src/surface-inventory.unit.test.ts scripts/audit-learner-copy.unit.test.ts",
    "test:usability:container": "pnpm rw:web:build && playwright test --config playwright.usability.config.ts",
    "test:usability": "pnpm test:usability:static && pnpm test:usability:container",
    "test:usability:install": "playwright install chromium",
    "smoke:local": "tsx scripts/smoke-local.ts",
    "api:smoke": "tsx scripts/api-smoke.ts",
    "gen:postman": "tsx scripts/gen-postman.ts",
    "gen:openapi": "tsx scripts/generate-openapi.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:local": "tsx scripts/migrate-local-db.ts",
    "worker:dev": "tsx scripts/worker.ts",
    "seed:synthetic": "tsx scripts/seed-synthetic.ts",
    "audit:schema": "tsx scripts/audit-schema-writes.ts",
    "audit:dependencies": "pnpm audit --prod --audit-level=high",
    "audit:api-contracts": "tsx scripts/audit-api-contracts.ts",
    "audit:partition": "tsx scripts/audit-test-partition.ts",
    "audit:profile": "tsx scripts/audit-profile.ts",
    "audit:learner-copy": "tsx scripts/audit-learner-copy.ts",
    "audit:no-learning-styles": "tsx scripts/audit-no-learning-styles.ts",
    "audit:draft-status": "tsx scripts/audit-draft-status.ts",
    "audit:draft-status-reads": "tsx scripts/audit-draft-status-reads.ts",
    "audit:relations": "tsx scripts/audit-relations.ts",
    "audit:mastery-provenance": "tsx scripts/audit-mastery-provenance.ts",
    "audit:fold-writes": "tsx scripts/audit-fold-writes.ts",
    "audit:flags": "tsx scripts/audit-flags.ts",
    "audit:calibration": "tsx scripts/audit-calibration.ts",
    "audit:projection": "tsx scripts/audit-projection.ts",
    "audit:tree-mesh": "tsx scripts/audit-tree-mesh-overlap.ts",
    "db:backfill:genesis": "tsx scripts/backfill-genesis-events.ts",
    "db:backfill:lost-attribution": "tsx scripts/backfill-lost-attribution.ts",
    "db:recompute:bcalib": "tsx scripts/recompute-bcalib-cap.ts",
    "rebuild:projection": "tsx scripts/rebuild-projection.ts",
    "b3:gate": "tsx scripts/b3-gate.ts",
    "capture:golden": "tsx scripts/capture-golden.ts",
    "audit:golden": "tsx scripts/golden-reaudit.ts",
    "capture:judge-golden": "tsx scripts/capture-judge-golden.ts",
    "audit:judge-golden": "tsx scripts/judge-golden-reaudit.ts",
    "audit:judge-prompts": "tsx scripts/judge-prompt-reaudit.ts",
    "normalize:edge-created-by": "tsx scripts/normalize-edge-created-by.ts",
    "normalize:qb-bbox": "tsx scripts/sweep-question-block-bbox.ts",
    "compile:profile": "tsx scripts/compile-profile.ts",
    "docs:linear-manifest": "tsx scripts/linear-doc-manifest.ts",
    "preflight:vision": "tsx scripts/preflight-vision.ts",
    "preflight:ingestion": "tsx scripts/ingestion-preflight.ts",
    "sanity:vision-rejudge": "tsx scripts/sanity-vision-rejudge.ts",
    "replay:urnings": "tsx scripts/replay-urnings-lite.ts",
    "report:teaching-brief": "tsx scripts/report-teaching-brief.ts",
    "compose:up": "tsx scripts/cloudflared-preflight.ts && docker compose up -d",
    "compose:down": "docker compose down",
    "compose:build": "docker compose build",
    "db:dump": "docker compose exec postgres pg_dump -U ${POSTGRES_USER:-loom} ${POSTGRES_DB:-loom} > /tmp/loom-$(date +%Y%m%d-%H%M%S).sql",
    "db:restore": "docker compose exec -T postgres psql -U ${POSTGRES_USER:-loom} ${POSTGRES_DB:-loom}",
    "rw:api": "RW_WORKER=1 tsx watch server/index.ts",
    "rw:web": "vite --config web/vite.config.ts",
    "rw:web:build": "vite build --config web/vite.config.ts",
    "build:server": "esbuild server/index.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/server.cjs --external:pg-native --external:sharp --external:better-sqlite3 --external:bufferutil --external:utf-8-validate --external:@anthropic-ai/claude-agent-sdk --external:@hyzyla/pdfium --define:process.env.NODE_ENV=\\\"production\\\"",
    "rw:build": "pnpm rw:web:build && pnpm build:server"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.215",
    "@anthropic-ai/sdk": "^0.112.4",
    "@aws-sdk/client-s3": "^3.1091.0",
    "@hono/node-server": "^2.0.10",
    "@hyzyla/pdfium": "^2.1.13",
    "@paralleldrive/cuid2": "^2.2.2",
    "@tanstack/react-query": "^5.101.3",
    "@tanstack/react-router": "^1.170.18",
    "@tiptap/core": "^3.28.0",
    "@tiptap/extension-link": "^3.28.0",
    "@tiptap/pm": "^3.28.0",
    "@tiptap/react": "^3.28.0",
    "@tiptap/starter-kit": "^3.28.0",
    "@tiptap/suggestion": "^3.28.0",
    "better-sqlite3": "^12.11.1",
    "client-zip": "^2.5.0",
    "cytoscape": "^3.34.0",
    "cytoscape-fcose": "^2.2.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.7.1",
    "fast-xml-parser": "^5.10.1",
    "fflate": "^0.8.3",
    "hono": "^4.12.31",
    "jsonrepair": "^3.15.0",
    "katex": "^0.18",
    "lucide-react": "^0.577.0",
    "mathjs": "^15.2.0",
    "mem0ai": "3.0.13",
    "pg": "^8.22.0",
    "pg-boss": "^12.26.1",
    "postgres": "^3.4.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10",
    "rehype-katex": "^7",
    "remark-math": "^6",
    "sharp": "^0.35.3",
    "tencentcloud-sdk-nodejs-ocr": "^4.1.268",
    "ts-fsrs": "^5.4.1",
    "undici": "^7.28.0",
    "zod": "^3.25.0",
    "zod-to-json-schema": "^3.25.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "^4.3.3",
    "@testcontainers/postgresql": "^12.0.4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/katex": "^0.16.8",
    "@types/node": "^24.13.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.3",
    "testcontainers": "^12.0.4",
    "tsx": "^4.23.1",
    "typescript": "7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
