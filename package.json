{
  "name": "the-learning-project",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "compose:up": "docker compose up -d",
    "compose:down": "docker compose down",
    "compose:build": "docker compose build",
    "db:dump": "docker compose exec postgres pg_dump -U ${POSTGRES_USER:-loom} ${POSTGRES_DB:-loom} > /tmp/loom-$(date +%Y%m%d-%H%M%S).sql",
    "db:restore": "docker compose exec -T postgres psql -U ${POSTGRES_USER:-loom} ${POSTGRES_DB:-loom}"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.76",
    "@aws-sdk/client-s3": "^3.700.0",
    "@paralleldrive/cuid2": "^2.2.2",
    "@tanstack/react-query": "^5.59.0",
    "ai": "^6.0.176",
    "client-zip": "^2.5.0",
    "drizzle-orm": "^0.36.0",
    "drizzle-zod": "^0.5.1",
    "fflate": "^0.8.2",
    "lucide-react": "^0.468.0",
    "next": "^15.0.0",
    "pg": "^8.20.0",
    "pg-boss": "^12.18.2",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5",
    "tencentcloud-sdk-nodejs-ocr": "^4.1.229",
    "ts-fsrs": "^5.3.2",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testcontainers/postgresql": "^10.13.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^2.1.5",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.27.0",
    "tailwindcss": "^4.0.0",
    "testcontainers": "^10.13.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.5"
  }
}
