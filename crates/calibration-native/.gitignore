# Build artifacts — the crate source is committed; binaries are built on demand
# (dev/CI-only, opt-in; see YUK-493). Differential test is skip-if-absent.
/target
*.node
node_modules
# napi-generated loader/types (regenerated by `napi build`)
index.js
index.d.ts
browser.js
# WASM (wasm32-wasi) artifacts + napi-generated WASI loaders (YUK-495 S5; `pnpm build:native:wasm`)
*.wasm
*.wasi.cjs
*.wasi-browser.js
wasi-worker.mjs
wasi-worker-browser.mjs
