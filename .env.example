# Server-side env. Loaded from .env.local in dev; from docker-compose env_file on NAS.

# Postgres — Drizzle. Use Neon pooled URL during dev, local PG (compose) on NAS.
DATABASE_URL=

# AI provider keys — current task registry routes to `xiaomi` (Mimo
# Anthropic-protocol-compat endpoint); ANTHROPIC_API_KEY is the fallback path
# if a task is rerouted to Anthropic direct. See src/server/ai/providers.ts.
ANTHROPIC_API_KEY=
XIAOMI_API_KEY=

# Internal auth (middleware.ts gates /api/* on this; /api/health exempt).
INTERNAL_TOKEN=

# Cloudflare R2 (S3-compatible) — Sub 0b1
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=

# Tencent OCR (used by ingestion). Sub 0c may add QuestionSplitOCR keys.
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_OCR_REGION=ap-shanghai

# Cloudflare Tunnel (Sub 0z) — runs cloudflared in the docker-compose stack.
# Generate via Zero Trust dashboard → Networks → Tunnels → Create tunnel.
TUNNEL_TOKEN=

# Postgres credentials for docker-compose (only used by the postgres service +
# the db:dump / db:restore scripts; the app reads DATABASE_URL above directly).
POSTGRES_USER=loom
POSTGRES_PASSWORD=loom
POSTGRES_DB=loom
