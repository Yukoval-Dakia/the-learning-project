# Server-side env. Loaded by docker-compose app/worker containers and host-side local wrappers.

# Docker compose runtime DATABASE_URL. This is for app/worker containers.
# Host-side local dev should use `pnpm dev:local`, which derives
# postgres://<POSTGRES_USER>:<POSTGRES_PASSWORD>@127.0.0.1:5433/<POSTGRES_DB>?sslmode=disable
# from the POSTGRES_* values below.
DATABASE_URL=postgres://loom:loom@postgres:5432/loom?sslmode=disable

# AI provider keys — current task registry routes to `xiaomi` (Mimo
# Anthropic-protocol-compat endpoint); ANTHROPIC_API_KEY is the fallback path
# if a task is rerouted to Anthropic direct. See src/server/ai/providers.ts.
ANTHROPIC_API_KEY=
XIAOMI_API_KEY=

# xiaomi/mimo vision overrides (defaults in scripts/preflight-vision.ts; used by
# the vision rescue path + `pnpm preflight:vision`). Leave unset to use defaults:
#   MIMO_VISION_BASE_URL  default: https://api.xiaomimimo.com/anthropic
#   MIMO_VISION_MODEL     default: mimo-v2.5
MIMO_VISION_BASE_URL=
MIMO_VISION_MODEL=

# Mem0 memory layer (YUK-37 / ADR-0017; reconfigured YUK-341 2026-06-14) —
# required as soon as the brief-writer worker handles its first event ingest job.
# Both halves now run over OpenAI-compatible endpoints (mem0ai 3.0.6's `openai`
# provider forwards config.baseURL — the old `anthropic` provider + the
# withXiaomiBaseUrl env-dance is gone):
#   - LLM (fact extraction) → 智谱 GLM 5.2, REUSES ZHIPU_API_KEY (set below for GLM-OCR)
#   - embedder              → 阿里百炼 text-embedding-v4, needs DASHSCOPE_API_KEY (new, here)
# Without these keys `src/server/memory/client.ts:createMem0Config` throws on the
# first enqueued memory_event_ingest job. See
# docs/design/2026-06-13-memory-architecture.md §8.3.
DASHSCOPE_API_KEY=

# Mem0 optional overrides (defaults live in src/server/memory/client.ts). Leave
# these COMMENTED OUT to use the defaults — a bare `KEY=` sets the var to "" (not
# unset), and createMem0Config treats empty-after-trim as "use the default", so
# either form is safe; commented-out just keeps the template honest. Uncomment +
# set a value only to override.
#   MEM0_LLM_MODEL=glm-5            # default glm-5.2 (智谱 GLM); set "glm-5" if 5.2 REST not yet GA
#   MEM0_LLM_BASE_URL=             # default https://open.bigmodel.cn/api/paas/v4 (no /v1 suffix)
#   MEM0_EMBEDDING_MODEL=         # default text-embedding-v4 (阿里百炼 DashScope)
#   MEM0_EMBEDDING_BASE_URL=     # default https://dashscope.aliyuncs.com/compatible-mode/v1 (has /v1)
#   MEM0_EMBEDDING_DIMS=         # default 1024 (embedder dims + pgvector column MUST match; positive int)
#   MEM0_PGVECTOR_COLLECTION=   # default learning_project_memories
#   MEM0_PGVECTOR_HNSW=         # default false (set "true" to enable HNSW on the pgvector store)
#   MEM0_PGVECTOR_DISKANN=     # default false (set "true" to enable DiskANN; mutually exclusive with HNSW)

# mem0 history (SQLite sidecar, disableHistory:false) — feeds the extraction
# prompt's "Last k Messages" (the sole benefit of keeping history on). The
# native better-sqlite3 module backs it (Dockerfile sqlitedeps overlay).
#   MEM0_HISTORY_DB_PATH: code default is /var/lib/mem0/history.db (absolute, to
#     dodge the relative-to-cwd multi-process footgun). Local dev (copy this file
#     → .env yourself; `pnpm dev:local` loads an existing .env, it does not copy)
#     can't write /var/lib, so point it at a repo-relative, gitignored path. PROD
#     does NOT use this value — the compose
#     app/worker services set MEM0_HISTORY_DB_PATH explicitly (worker → the
#     mem0data volume, app → /tmp ephemeral) and force MEM0_TELEMETRY=false.
MEM0_HISTORY_DB_PATH=./.mem0/history.db
# mem0 phones PostHog on every add/search/update/delete unless this is exactly
# "false". Off here for local dev too; compose re-asserts it for prod.
MEM0_TELEMETRY=false

# YUK-101 (iter2 fix F15) — opt-out for memory ingest enqueue. When set to
# any non-empty value, `defaultMemoryIngestEnqueuer` skips the dynamic
# import + boss.send entirely. Useful for admin scripts (`pnpm tsx
# scripts/...`) and REPL invocations that legitimately don't have the
# pg-boss worker available; without this, every writeEvent in those
# contexts logs a swallowed error. Leave unset in app/worker containers.
SKIP_BOSS_INGEST=

# YUK-148 / ADR-0023 — cross-process editing presence. When set, the Next app
# (heartbeats) and the pg-boss worker (note-refine idle checks) share editing
# presence via this Redis so the worker won't apply an AI patch mid-edit. In
# docker-compose this is injected as redis://redis:6379 for both services — so
# LEAVE THIS EMPTY in the template: local dev (pnpm dev:local copies .env.example
# → .env) with an empty REDIS_URL uses the in-memory fallback and needs no local
# Redis. A non-empty value here would make local dev try to reach the docker-only
# `redis` host. Unset (host-side single process) → in-memory fallback. Presence is
# ephemeral; lost presence on restart safely reads as idle.
REDIS_URL=

# Internal auth (middleware.ts gates /api/* on this; /api/health exempt).
INTERNAL_TOKEN=

# Cloudflare R2 (S3-compatible) — Sub 0b1
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=

# GLM-OCR (YUK-253) — DEFAULT extraction OCR engine (Zhipu GLM-OCR
# layout_parsing). Replaces Tencent as the character-level text + layout source;
# the VLM StructureTask still owns the structure tree (ADR-0002 / YUK-145).
# Source: open.bigmodel.cn console. REQUIRED on the default path — with
# EXTRACT_OCR_ENGINE unset/'glm', a missing key fails every extraction permanent.
# Billable: 0.2 元/M tokens (input=output), logged to cost_ledger (provider 'glm').
# Engine selector / rollback flag. 'glm' (default, unset == glm) | 'tencent'
# (retained as the permanent rollback path). Set to 'tencent' to fall
# back to the Tencent QuestionMarkAgent engine (requires the TENCENT_* keys below).
# EXTRACT_OCR_ENGINE=glm
ZHIPU_API_KEY=

# Tencent OCR (used by ingestion). Sub 0c may add QuestionSplitOCR keys.
# PHASE-DEFERRED (YUK-253): retained as the EXTRACT_OCR_ENGINE='tencent' rollback
# engine. Keep set during the GLM bake-in window so the fallback stays available.
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_OCR_REGION=ap-shanghai

# T-OC slice 3 (YUK-145, OC-4/OC-5) — WorkflowJudge auto-enroll.
#
#   !!! OFF BY DEFAULT. !!!  With this UNSET (the default), the WorkflowJudge
#   auto-enroll path is a NO-OP: nothing is auto-enrolled, every captured block
#   goes to the existing human review flow, production behaviour is unchanged.
#
# This flag is opt-IN (the INVERSE of WAVE6_TRIGGER_* which are opt-OUT): set it
# to EXACTLY "true" (case-insensitive) to let high-confidence captures auto-enroll
# with generated_by='workflow_judge'. Both OC-5 conservative-rollout gates are now
# satisfied: the "AI auto-enrolled N items" review surface shipped (PR #328 — the
# /record auto_enrolled review tab + revert) and the owner opted in (YUK-164 #4,
# 2026-06-08). Enable per environment as needed (prod: NAS docker-compose .env).
# The threshold below (default 0.85) keeps all but the highest-confidence captures
# in human review. See src/server/ingestion/workflow-judge-config.ts.
WORKFLOW_JUDGE_AUTO_ENROLL_ENABLED=
# Combined-confidence threshold for routing 'auto' (default 0.85; clamped [0,1]).
WORKFLOW_JUDGE_AUTO_ENROLL_THRESHOLD=

# YUK-258 — DOCX ingestion converter seam (src/server/ingestion/docx/convert.ts).
#
#   !!! NOT an on/off feature gate. !!!  The docx upload endpoint is always
#   available; this var only overrides which converter binary the seam uses.
#
# UNSET (default): the seam probes `which pandoc` / `which soffice`. In the prod
# runner image these are apt-installed (Dockerfile) so binaries are used directly.
# Set to EXACTLY "docker" to FORCE the docker-run fallback (pandoc/core +
# linuxserver/libreoffice images) — useful in local dev where the host has no
# pandoc/soffice on PATH and you'd rather not install them. Any other value is
# ignored (= unset behaviour).
DOCX_CONVERT_ENGINE=

# Cloudflare Tunnel (Sub 0z) — runs cloudflared in the docker-compose stack.
# Generate via Zero Trust dashboard → Networks → Tunnels → Create tunnel.
TUNNEL_TOKEN=

# Postgres credentials for docker-compose (only used by the postgres service +
# the db:dump / db:restore scripts; the app reads DATABASE_URL above directly).
POSTGRES_USER=loom
POSTGRES_PASSWORD=loom
POSTGRES_DB=loom
