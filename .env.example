# Server-side env. Loaded by docker-compose app/worker containers and host-side local wrappers.

# Docker compose runtime DATABASE_URL. This is for app/worker containers.
# Host-side local dev should use `pnpm dev:local`, which derives
# postgres://<POSTGRES_USER>:<POSTGRES_PASSWORD>@127.0.0.1:5433/<POSTGRES_DB>?sslmode=disable
# from the POSTGRES_* values below.
DATABASE_URL=postgres://loom:loom@postgres:5432/loom?sslmode=disable

# AI provider keys — current task registry routes to `xiaomi` (Mimo
# Anthropic-protocol-compat endpoint); ANTHROPIC_API_KEY is the fallback path
# if a task is rerouted to Anthropic direct. See src/server/ai/providers.ts.
ANTHROPIC_API_KEY=
XIAOMI_API_KEY=

# Mem0 memory layer (YUK-37 / ADR-0017) — required as soon as the brief-writer
# worker handles its first event ingest job. The fact layer defaults to Mem0's
# `openai` embedder (decision recorded in ADR-0017 errata 2026-05-27 +
# docs/superpowers/plans/2026-05-27-t37-mem0-spike-findings.md). Without this
# key `src/server/memory/client.ts:createMem0Config` throws on the first
# enqueued memory_event_ingest job.
OPENAI_API_KEY=

# Mem0 optional overrides (defaults live in src/server/memory/client.ts):
#   MEM0_EMBEDDING_MODEL   default: text-embedding-3-small
#   MEM0_EMBEDDING_DIMS    default: 1536
#   MEM0_LLM_MODEL         default: mimo-v2.5-pro (Mimo via Anthropic-compat endpoint)
#   MEM0_PGVECTOR_COLLECTION  default: learning_project_memories
#   MEM0_PGVECTOR_HNSW     default: false  (set to "true" to enable HNSW on the pgvector store)
#   MEM0_PGVECTOR_DISKANN  default: false  (set to "true" to enable DiskANN; mutually exclusive with HNSW in practice)
#   MEM0_ANTHROPIC_BASE_URL  default: https://api.xiaomimimo.com/anthropic (Mimo)
MEM0_EMBEDDING_MODEL=
MEM0_EMBEDDING_DIMS=
MEM0_LLM_MODEL=
MEM0_PGVECTOR_COLLECTION=
MEM0_PGVECTOR_HNSW=
MEM0_PGVECTOR_DISKANN=
MEM0_ANTHROPIC_BASE_URL=

# Internal auth (middleware.ts gates /api/* on this; /api/health exempt).
INTERNAL_TOKEN=

# Cloudflare R2 (S3-compatible) — Sub 0b1
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=

# Tencent OCR (used by ingestion). Sub 0c may add QuestionSplitOCR keys.
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_OCR_REGION=ap-shanghai

# Cloudflare Tunnel (Sub 0z) — runs cloudflared in the docker-compose stack.
# Generate via Zero Trust dashboard → Networks → Tunnels → Create tunnel.
TUNNEL_TOKEN=

# Postgres credentials for docker-compose (only used by the postgres service +
# the db:dump / db:restore scripts; the app reads DATABASE_URL above directly).
POSTGRES_USER=loom
POSTGRES_PASSWORD=loom
POSTGRES_DB=loom
