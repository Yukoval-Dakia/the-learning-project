[
  {
    "path": "/api/_/export",
    "methods": [
      {
        "method": "GET",
        "summary": "导出数据库 + 可选 R2 资产为 ZIP 压缩包",
        "query": [
          {
            "name": "include_assets",
            "required": false,
            "example": "1"
          }
        ],
        "contentType": null,
        "bodyExample": null,
        "notes": "响应 content-type: application/zip，attachment 下载；include_assets=1 时打包 R2 资产"
      }
    ]
  },
  {
    "path": "/api/_/import",
    "methods": [
      {
        "method": "POST",
        "summary": "上传 ZIP 备份档案，wipe-and-reload 恢复数据库",
        "query": [
          {
            "name": "confirm",
            "required": true,
            "example": "wipe-and-reload"
          }
        ],
        "contentType": "application/octet-stream",
        "bodyExample": null,
        "notes": "请求体为原始 ZIP 二进制（application/octet-stream）；confirm 参数值必须精确为 wipe-and-reload，否则返回 400。破坏性：会清库重载"
      }
    ]
  },
  {
    "path": "/api/admin/cost",
    "methods": [
      {
        "method": "GET",
        "summary": "查询过去 N 天的 AI 调用成本聚合",
        "query": [
          {
            "name": "days",
            "required": false,
            "example": "30"
          }
        ],
        "contentType": null,
        "bodyExample": null,
        "notes": "days 默认 30；返回 getAdminCost 聚合结果"
      }
    ]
  },
  {
    "path": "/api/admin/failures",
    "methods": [
      {
        "method": "GET",
        "summary": "获取 AI 任务失败集群列表",
        "query": [
          {
            "name": "limit",
            "required": false,
            "example": "200"
          }
        ],
        "contentType": null,
        "bodyExample": null,
        "notes": "limit 默认 200，最大 200；返回 {clusters, limit}"
      }
    ]
  },
  {
    "path": "/api/admin/runs",
    "methods": [
      {
        "method": "GET",
        "summary": "分页列出 AI task runs，支持 status / task_kind 过滤",
        "query": [
          {
            "name": "limit",
            "required": false,
            "example": "50"
          },
          {
            "name": "status",
            "required": false,
            "example": "failure"
          },
          {
            "name": "task_kind",
            "required": false,
            "example": "VariantVerifyTask"
          }
        ],
        "contentType": null,
        "bodyExample": null,
        "notes": "status 允许值：running、success、failure；limit 默认 50"
      }
    ]
  },
  {
    "path": "/api/admin/runs/:id",
    "methods": [
      {
        "method": "GET",
        "summary": "获取单个 AI task run 的详细时间线",
        "query": [],
        "contentType": null,
        "bodyExample": null,
        "notes": ":id 为 task_run_id；不存在返回 404"
      }
    ]
  },
  {
    "path": "/api/agents/notes",
    "methods": [
      {
        "method": "GET",
        "summary": "读取全部未过期的跨 agent 观察笔记（AI 观察板只读接口）",
        "query": [
          {
            "name": "limit",
            "required": false,
            "example": "50"
          }
        ],
        "contentType": null,
        "bodyExample": null,
        "notes": "limit 正整数 max 200；响应 { rows: [...] }"
      }
    ]
  },
  {
    "path": "/api/copilot/chat",
    "methods": [
      {
        "method": "POST",
        "summary": "向 Copilot 发送一条用户消息，响应为 SSE 流（text/event-stream）",
        "query": [],
        "contentType": "application/json",
        "bodyExample": {
          "user_message": "帮我讲解之字主谓间用法",
          "triggered_by": "chat",
          "chip_kind": null,
          "skill_context": null,
          "ambient_context": {
            "route": "/today",
            "focused_entity": {
              "kind": "knowledge_node",
              "id": "k_abc123"
            }
          }
        },
        "notes": "SSE 流式。triggered_by 枚举：chat|chip。响应事件：event: delta（data {text}）逐块；event: reply（data CopilotChatResult）终止。Zod 失败时返回普通 JSON 错误。需 x-internal-token"
      }
    ]
  },
  {
    "path": "/api/copilot/turns",
    "methods": [
      {
        "method": "GET",
        "summary": "获取最近 N 条 Copilot 对话轮次（ask/chip + reply 对），oldest→newest",
        "query": [
          {
            "name": "limit",
            "required": false,
            "example": "20"
          }
        ],
        "contentType": null,
        "bodyExample": null,
        "notes": "limit 正整数，省略用服务端默认；响应 { turns: [...] }"
      }
    ]
  },
  {
    "path": "/api/cost/today",
    "methods": [
      {
        "method": "GET",
        "summary": "返回今日（BJT 午夜起）的花费汇总，用于 /today cost ribbon",
        "query": [],
        "contentType": null,
        "bodyExample": null,
        "notes": "按 BJT（UTC+8）午夜划窗口；返回 {window, today:{spend,tokens_in,tokens_out,ledger_rows,tool_calls,by_task}}"
      }
    ]
  },
  {
    "path": "/api/editing-session/blur",
    "methods": [
      {
        "method": "POST",
        "summary": "用户离焦（blur）时将 artifact 标记为 idle 并触发 flush",
        "query": [],
        "contentType": "application/json",
        "bodyExample": {
          "artifact_id": "art_abc123"
        },
        "notes": "artifact_id 非空字符串；响应为 flush 结果"
      }
    ]
  },
  {
    "path": "/api/editing-session/heartbeat",
    "methods": [
      {
        "method": "POST",
        "summary": "记录 artifact 编辑心跳；status=editing 时同时入队 dwell note-refine 任务",
        "query": [],
        "contentType": "application/json",
        "bodyExample": {
          "artifact_id": "art_abc123",
          "status": "editing"
        },
        "notes": "status 枚举：editing|idle；editing 时额外入队后台精炼；响应 { ok: true }"
      }
    ]
  },
  {
    "path": "/api/embedded-check/attempt",
    "methods": [
      {
        "method": "POST",
        "summary": "提交内联检查题答案，判题并（失败时）记录 mistake + 入队 attribution_followup，不写 FSRS",
        "query": [],
        "contentType": "application/json",
        "bodyExample": {
          "question_id": "q_abc123",
          "answer_md": "答案文本",
          "latency_ms": 3000
        },
        "notes": "question.source 须为 embedded 或 teaching_check；answer_md 最大 2000；latency_ms 可选 0-3600000；响应含 outcome + judge + attempt_event_id + (mistake_id)"
      }
    ]
  },
  {
    "path": "/api/events/:id/correct",
    "methods": [
      {
        "method": "POST",
        "summary": "为目标事件写入 correct 事件（标记 supersede/retract/mark_wrong/restore）",
        "query": [],
        "contentType": "application/json",
        "bodyExample": {
          "correction_kind": "retract",
          "reason_md": "判题有误",
          "affected_refs": [
            {
              "kind": "question",
              "id": "q_abc123"
            }
          ]
        },
        "notes": "correction_kind 枚举：supersede|retract|mark_wrong|restore；supersede 须带 replacement_event_id，其余 kind 不得携带；affected_refs 最少 1 项；ActivityRef.kind 枚举：question|question_part|record|recall_prompt|practice_log|project_milestone|open_inquiry"
      }
    ]
  },
  {
    "path": "/api/health",
    "methods": [
      {
        "method": "GET",
        "summary": "服务健康探针，同步检测 DB 连接",
        "query": [],
        "contentType": null,
        "bodyExample": null,
        "notes": "无需 x-internal-token（中间件豁免）；db_ok=false 时返回 HTTP 503；ok 字段始终为 true"
      }
    ]
  },
  {
    "path": "/api/hubs/:id/dismiss-link",
    "methods": [
      {
        "method": "POST",
        "summary": "从 hub 的 AutoLinksContainer 中压制（dismiss）一条系统维护的 auto-link",
        "query": [],
        "contentType": "application/json",
        "bodyExample": {
          "suppressed_artifact_id": "artifact_xyz789",
          "relation": "subtopic"
        },
        "notes": "relation 可选，枚举：subtopic|prerequisite|derived_from|contrasts_with；suppressed_artifact_id 不能等于 hub id；操作幂等；单事务原子"
      }
    ]
  },
  {
    "path": "/api/mistakes",
    "methods": [
      {
        "method": "POST",
        "summary": "录入一条错题：创建 question + attempt event + learning_record，异步触发 AI 提议",
        "query": [],
        "contentType": "application/json",
        "bodyExample": {
          "prompt_md": "下列句子中「而」字的用法是？",
          "reference_md": "《劝学》原文片段",
          "wrong_answer_md": "我认为是转折用法",
          "knowledge_ids": ["kid_abc123"],
          "cause": {
            "primary_category": "misunderstanding",
            "user_notes": "混淆了顺承与转折"
          },
          "difficulty": 3,
          "question_kind": "short_answer",
          "prompt_image_refs": [],
          "wrong_answer_image_refs": []
        },
        "notes": "knowledge_ids 至少 1 个且须存在未归档；cause 可为 null（null 时异步触发 attribution job）；CauseCategory 匹配 /^[a-z][a-z0-9_]*$/；question_kind 枚举见 import；image_refs 须已上传 asset id；响应含 question_id、mistake_id、record_id"
      },
      {
        "method": "GET",
        "summary": "查询错题列表（event-stream 投影），支持时间过滤和 question 过滤",
        "query": [
          {
            "name": "limit",
            "required": false,
            "example": "50"
          },
          {
            "name": "since",
            "required": false,
            "example": "2026-01-01T00:00:00Z"
          },
          {
            "name": "question_id",
            "required": false,
            "example": "qid_abc123"
          }
        ],
        "contentType": null,
        "bodyExample": null,
        "notes": "limit 默认 50 上限 200；since 为 ISO-8601；投影 shape：id/question_id/prompt_md/wrong_answer_md/knowledge_ids/cause/created_at"
      }
    ]
  },
  {
    "path": "/api/questions",
    "methods": [
      {
        "method": "GET",
        "summary": "多轴题库列表（knowledge_id/subject/source/kind/difficulty/visual_complexity/source_tier/family 过滤）",
        "query": [
          {
            "name": "knowledge_id",
            "required": false,
            "example": "kn_abc123"
          },
          {
            "name": "subject",
            "required": false,
            "example": "wenyan"
          },
          {
            "name": "source",
            "required": false,
            "example": "manual"
          },
          {
            "name": "kind",
            "required": false,
            "example": "short_answer"
          },
          {
            "name": "difficulty",
            "required": false,
            "example": "3"
          },
          {
            "name": "visual_complexity",
            "required": false,
            "example": "low"
          },
          {
            "name": "source_tier",
            "required": false,
            "example": "1"
          },
          {
            "name": "sort_by",
            "required": false,
            "example": "source_tier"
          },
          {
            "name": "group_by_family",
            "required": false,
            "example": "true"
          },
          {
            "name": "expand_root",
            "required": false,
            "example": "q_root123"
          },
          {
            "name": "include_drafts",
            "required": false,
            "example": "false"
          },
          {
            "name": "limit",
            "required": false,
            "example": "50"
          },
          {
            "name": "offset",
            "required": false,
            "example": "0"
          }
        ],
        "contentType": null,
        "bodyExample": null,
        "notes": "knowledge_id/source_tier 可多值；group_by_family 与 expand_root 互斥；expand_root 不能与 source_tier/sort_by 同用；limit 上限 200；sort_by 枚举：created_at|source_tier"
      }
    ]
  },
  {
    "path": "/api/questions/:id",
    "methods": [
      {
        "method": "GET",
        "summary": "单题详情聚合（题行 + source_tier + labels + 变体家族 + per-knowledge FSRS/decay + 反向链接 + timeline）",
        "query": [
          {
            "name": "timeline_limit",
            "required": false,
            "example": "10"
          }
        ],
        "contentType": null,
        "bodyExample": null,
        "notes": "timeline_limit 默认 10 上限 50"
      },
      {
        "method": "PATCH",
        "summary": "编辑题库可编辑字段（prompt/reference/choices/difficulty/knowledge_ids/kind/draft_status）；bloodline 字段一律 400",
        "query": [],
        "contentType": "application/json",
        "bodyExample": {
          "version": 0,
          "prompt_md": "新题目文本",
          "reference_md": "参考答案",
          "choices_md": ["A", "B", "C", "D"],
          "difficulty": 3,
          "knowledge_ids": ["kn_abc"],
          "kind": "short_answer",
          "draft_status": "active"
        },
        "notes": "version 乐观锁；至少提供一个可编辑字段；bloodline 字段被拒；kind 枚举见 import；draft_status 枚举：draft|active"
      },
      {
        "method": "DELETE",
        "summary": "软归档题目两步：不带 confirm 返回 409+关联计数；?confirm=true&version=N 执行软归档",
        "query": [
          {
            "name": "confirm",
            "required": false,
            "example": "true"
          },
          {
            "name": "version",
            "required": false,
            "example": "0"
          }
        ],
        "contentType": null,
        "bodyExample": null,
        "notes": "不带 confirm=true 始终 409；confirm=true 时 version 必填；软归档=设回 draft"
      }
    ]
  },
  {
    "path": "/api/teaching-sessions/:id/accept-chip",
    "methods": [
      {
        "method": "POST",
        "summary": "记录用户点击 suggestion chip（写 accept_suggestion 事件），可选触发 proposal accept",
        "query": [],
        "contentType": "application/json",
        "bodyExample": {
          "suggestion_kind": "proactive",
          "chip_label": "继续讲解",
          "source_event_id": null,
          "target_tool": null,
          "target_args": null,
          "proposal_id": null
        },
        "notes": "suggestion_kind 枚举：proactive|corrective；source_event_id 省略时自动解析；proposal_id 有值时先 acceptAiProposal；session 须 active"
      }
    ]
  },
  {
    "path": "/api/today/copilot-summary",
    "methods": [
      {
        "method": "GET",
        "summary": "获取 Copilot Drawer 摘要槽数据（Coach scan + Dreaming preview + 待审提案数）",
        "query": [],
        "contentType": null,
        "bodyExample": null,
        "notes": "响应为 CopilotSummary JSON"
      }
    ]
  }
]
