.DS_Store
node_modules/
.env
.env.local
.idea/
.vscode/

# Build
dist/
.cache/

# Test coverage reports (@vitest/coverage-v8 output — generated, never committed)
coverage/

# Wrangler runtime artifacts (leftover from old workers/ setup)
.wrangler/
.wrangler-state/
.dev.vars
workers/

# Drizzle generated
drizzle/.snapshots/

# Vercel
.vercel/
.next/

# Next.js
next-env.d.ts
tsconfig.tsbuildinfo

.env*.local

# Claude Code per-user local overrides (project shared settings go in settings.json)
.claude/settings.local.json

# Per-user local MCP server config (machine-specific tokens / paths)
.mcp.json

# mem0 history SQLite sidecar for local dev (MEM0_HISTORY_DB_PATH=./.mem0/...;
# prod uses the compose mem0data volume / /tmp). Machine-local, never commit.
.mem0/

# Subagent worktrees (created by Agent tool with isolation:"worktree")
.claude/worktrees/
.playwright-mcp/

# Scheduled-tasks runtime lock (ScheduleWakeup / loop artifact)
.claude/scheduled_tasks.lock

# remember skill hook logs
.remember/

# Manual sanity / preflight output — run locally, not committed
docs/preflight/*-vision-rejudge.json

# pnpm package store cache (machine-local, ~866 MB; never commit)
.pnpm-store/

# Local agent/tool state dirs (opencode, omo, omc, ocx) — machine-local, never
# commit; no leading slash so a nested .omc/ (hook-created inside src/) is
# caught too
.ocx/
.omc/
.omo/
.opencode/

# Cursor IDE runtime hook state (continual-learning.json etc.) — runtime-mutated
# state the Cursor hook keeps rewriting + auto-committing; was wrongly tracked and
# caused perpetual checkout conflicts. rules/ (.cursor/rules/*.mdc) stays tracked.
.cursor/hooks/state/

# External sample/tutorial clones dropped into the repo root — not project source
getting-started-with-browserbase/
docling-docx-parse-output/
